{
  "name": "jazzene",
  "private": true,
  "type": "module",
  "scripts": {
    "check_all": "npm run format && npm run check && npm run test && npm run build && E2E_PREVIEW=1 npm run test:e2e",
    "check": "moon check src && moon fmt --check",
    "format": "NEW_MOON_PKG=1 moon fmt",
    "test": "moon test -p internal/jazzene/music internal/jazzene/music/generator internal/jazzene/music/sheet internal/jazzene/music/midi --target wasm-gc",
    "test:e2e": "playwright test",
    "dev": "vite",
    "preview": "vite preview --port 4173",
    "start": "npm run dev -- --open",
    "build": "moon build --release && vite build",
    "download:samples": "bash scripts/download-samples.sh",
    "tunnel": "cloudflared tunnel --url localhost:5173",
    "update:skills": "bash scripts/update-skills.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "lefthook": "^2.1.6",
    "tailwindcss": "^4.0.2",
    "vite": "^8.0.8",
    "vite-plugin-moonbit": "^0.2.1"
  }
}
